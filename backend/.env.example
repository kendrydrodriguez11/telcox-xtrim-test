# Clave secreta de Flask — Es opcional pero mejor cambialas por unas mas seguras
SECRET_KEY=telcox-bss-change-in-production

# Conexión a MySQL — reemplazar usuario y contraseña con tus credenciales correctas
DATABASE_URL=mysql+pymysql://root:password@localhost/telcox_db

# Modo de ejecución — usa "development" para desarrollo local
FLASK_ENV=development
